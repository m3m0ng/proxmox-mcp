# proxmox-mcp configuration — copy to .env and fill in real values.
# .env is git-ignored; NEVER commit real credentials.
# In deployment, an MCP client's "env" block can set these instead and will
# override anything in .env.

# Proxmox host or IP (optionally "host:port"; port defaults to 8006)
PROXMOX_HOST=192.168.1.10

# API token identity: user@realm and the token id
PROXMOX_USER=agent@pve
PROXMOX_TOKEN_NAME=mcp

# The token secret (shown only once when you create the token)
PROXMOX_TOKEN_VALUE=replace-with-your-token-secret

# Set to "true" only if the Proxmox API has a trusted (non-self-signed) cert
PROXMOX_VERIFY_SSL=false

# Optional, defaults to 8006
# PROXMOX_PORT=8006

# --- Optional: in-guest command execution (Tier D', OFF by default) ---
# Lets agents run commands INSIDE guests via SSH to the host (pct/qm exec).
# This is a real privilege grant — see the README security note before enabling.
# PROXMOX_ENABLE_EXEC=true
# PROXMOX_SSH_HOST=192.168.1.10   # defaults to PROXMOX_HOST
# PROXMOX_SSH_PORT=22
# PROXMOX_SSH_USER=root
# PROXMOX_SSH_KEY_FILE=/home/you/.ssh/proxmox_agent   # preferred
# PROXMOX_SSH_PASSWORD=                                # used only if no key file
